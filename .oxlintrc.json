{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn", "oxc", "import"],
	"categories": {
		"correctness": "error",
		"suspicious": "warn",
		"perf": "warn"
	},
	"rules": {
		"import/no-unassigned-import": "off"
	},
	"ignorePatterns": ["build", ".svelte-kit", ".svelte-check", "static"]
}

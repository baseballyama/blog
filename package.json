{
  "name": "blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">= 22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "rm -rf docs && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:tsgo": "svelte-kit sync && svelte-check --tsgo --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@rsvelte/svelte-check": "^0.1.4",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^24.0.0",
    "svelte": "^5.56.0",
    "typescript": "^5.7.0",
    "vite": "^7.1.0"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "marked": "^17.0.0"
  },
  "pnpm": {
    "overrides": {
      "@sveltejs/vite-plugin-svelte": "npm:@rsvelte/vite-plugin-svelte@^0.3.0",
      "@rsvelte/vite-plugin-svelte-native": "^0.2.1"
    },
    "onlyBuiltDependencies": [
      "@resvg/resvg-js",
      "@rsvelte/vite-plugin-svelte-native",
      "esbuild"
    ]
  }
}

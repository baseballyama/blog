{
	"name": "blog",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "node scripts/fetch-stars.mjs && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"check": "svelte-kit sync && rsvelte-check --tsgo --incremental --tsconfig ./tsconfig.json",
		"check:legacy": "svelte-kit sync && rsvelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && rsvelte-check --tsgo --incremental --tsconfig ./tsconfig.json --watch",
		"lint": "oxlint && rsvelte-lint src/",
		"lint:fix": "oxlint --fix && rsvelte-lint --fix src/",
		"lint:ci": "oxlint --deny-warnings && rsvelte-lint --max-warnings 0 src/",
		"format": "rsvelte-fmt",
		"format:check": "rsvelte-fmt --check"
	},
	"dependencies": {
		"@resvg/resvg-js": "^2.6.2",
		"marked": "^18.0.0",
		"mermaid": "^11.16.0"
	},
	"devDependencies": {
		"@fontsource-variable/jetbrains-mono": "^5.3.0",
		"@rsvelte/fmt": "^0.6.2",
		"@rsvelte/lint": "^0.8.2",
		"@rsvelte/svelte-check": "^0.5.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.1",
		"@typescript/native-preview": "7.0.0-dev.20260707.2",
		"oxfmt": "^0.60.0",
		"oxlint": "^1.67.0",
		"svelte": "^5.56.0",
		"typescript": "^6.0.0",
		"vite": "^8.0.0"
	},
	"engines": {
		"node": ">= 22.12"
	},
	"packageManager": "pnpm@11.15.1"
}

{
	"name": "blog",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "node scripts/fetch-stars.mjs && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"check": "svelte-kit sync && rsvelte-check --tsgo --incremental --tsconfig ./tsconfig.json",
		"check:legacy": "svelte-kit sync && rsvelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && rsvelte-check --tsgo --incremental --tsconfig ./tsconfig.json --watch",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check"
	},
	"dependencies": {
		"@resvg/resvg-js": "^2.6.2",
		"marked": "^18.0.0",
		"mermaid": "^11.16.0"
	},
	"devDependencies": {
		"@fontsource-variable/jetbrains-mono": "^5.3.0",
		"@rsvelte/svelte-check": "^0.3.10",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.1",
		"@typescript/native-preview": "7.0.0-dev.20260527.2",
		"oxfmt": "^0.52.0",
		"oxlint": "^1.67.0",
		"svelte": "^5.56.0",
		"typescript": "^6.0.0",
		"vite": "^7.3.0"
	},
	"engines": {
		"node": ">= 22"
	},
	"packageManager": "pnpm@10.25.0",
	"pnpm": {
		"overrides": {
			"@sveltejs/vite-plugin-svelte": "npm:@rsvelte/vite-plugin-svelte@^0.4.1",
			"@rsvelte/vite-plugin-svelte-native": "^0.2.6"
		},
		"onlyBuiltDependencies": [
			"@resvg/resvg-js",
			"@rsvelte/vite-plugin-svelte-native",
			"esbuild"
		]
	}
}
